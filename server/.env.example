# Copy this to .env and fill in your values

# Firebase — download your service account key from:
# Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# JWT — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Mapbox — get your public token from https://account.mapbox.com
# (this is exposed to the frontend; restrict it to your domain in Mapbox dashboard)
MAPBOX_TOKEN=pk.eyJ1Ijoi...

# Server
PORT=3000
NODE_ENV=development

# CORS origins allowed to call the API (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://localhost:3000
